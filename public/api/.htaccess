<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /api/

  # Support pretty URLs for clean PHP API routes
  RewriteRule ^products/([^/]+)/?$ products.php?id=$1 [L,QSA]
  RewriteRule ^products/?$ products.php [L,QSA]
  RewriteRule ^categories/?$ categories.php [L,QSA]
  RewriteRule ^reviews/?$ reviews.php [L,QSA]
</IfModule>
